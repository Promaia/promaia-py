# =============================================================================
# Promaia Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# === AI Model API Keys (at least one required) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === Google / Gemini Model Configuration ===
# Options: pro, flash, 2.0-flash, 2.0-flash-thinking
# Or a full model ID like: gemini-2.0-flash-exp
GOOGLE_DEFAULT_MODEL=pro

# === Optional: Local LLM (Ollama, LM Studio) ===
# LLAMA_BASE_URL=http://localhost:11434
# LLAMA_API_KEY=
# LLAMA_DEFAULT_MODEL=llama3:latest

# === Image Processing ===
# Threshold (MB) for Gemini File API vs base64 encoding
GEMINI_FILE_API_THRESHOLD_MB=20

# === Optional Integrations ===
MAILERLITE_API_KEY=
WEBFLOW_API_KEY=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=

# === Gmail ===
GMAIL_PERSONAL_EMAIL=
GMAIL_TRASS_EMAIL=

# === Shopify ===
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# === Debug Mode (0=off, 1=on) ===
MAIA_DEBUG=0
