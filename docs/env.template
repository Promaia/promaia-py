# Environment Variables Template for Maia
# Copy this file to .env and fill in your actual API keys and values

# AI Model API Keys (for chat functionality)
OPENAI_API_KEY='your_openai_api_key_here'
ANTHROPIC_API_KEY='your_anthropic_api_key_here'
GOOGLE_API_KEY='your_google_api_key_here'

# Google/Gemini Model Configuration
# Choose which Gemini model to use by default
# Options: pro, flash, 2.0-flash, 2.0-flash-thinking, exp-1206, exp-1121
# Or use full model ID like: gemini-2.0-flash-exp
GOOGLE_DEFAULT_MODEL='pro'  # Default: pro (Gemini 2.5 Pro)

# Local Llama Configuration (for local AI models)
# Set these if you're running a local Llama instance (e.g., Ollama, LM Studio)
LLAMA_BASE_URL='http://localhost:11434'  # Default Ollama URL
LLAMA_API_KEY='your_local_llama_api_key_or_leave_empty'  # Usually not needed for local setups
LLAMA_DEFAULT_MODEL='llama3:latest'  # Default model to use

# Gemini Image Processing Configuration
# Threshold in MB for when to use Gemini File API vs base64 encoding
# Images larger than this will be uploaded via File API (supports up to 2GB)
# Images smaller will use base64 encoding (faster, no upload needed)
GEMINI_FILE_API_THRESHOLD_MB='20'  # Default: 20MB

# Marketing/Newsletter API Keys
MAILERLITE_API_KEY='your_mailerlite_api_key_here'

# Webflow Integration
WEBFLOW_API_KEY='your_webflow_api_key_here'
WEBFLOW_SITE_ID='your_webflow_site_id_here'
WEBFLOW_COLLECTION_ID='your_webflow_collection_id_here'

# CMS Pipeline Configuration
# CMS settings (image processing, Webflow uploads) are configured in conf/cms.json
# See conf/README.md for detailed configuration options
# Key settings include:
#   - WebP image conversion (enabled by default)
#   - Compression quality (default: 85)
#   - Image size limits (default: 2048px max dimension)
# You can disable WebP conversion or adjust settings by editing conf/cms.json

# Legacy Notion Token (keep for backward compatibility)
NOTION_TOKEN='your_legacy_notion_token_here'

# Debug Mode (0 = off, 1 = on)
MAIA_DEBUG='0'

# Notion Workspace API Keys
NOTION_KOII_API_KEY='your_koii_workspace_notion_token_here'
NOTION_TRASS_API_KEY='your_trass_workspace_notion_token_here'

# Gmail Configuration
GMAIL_PERSONAL_EMAIL='your_personal_email@gmail.com'
GMAIL_TRASS_EMAIL='your_business_email@company.com' 